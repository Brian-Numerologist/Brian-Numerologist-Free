      },
      {
        "step_number": 11,
        "section_id": "STEP_11_SERVICE_ECOSYSTEM",
        "title": "BƯỚC 11 – HỆ SINH THÁI THẦN SỐ HỌC",
        "source_type": "cta"
      }
    ]
  },
